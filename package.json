{
  "name": "monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "turbo": "^2.8.11",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  }
}
