# 사이트 도메인 (OG 메타데이터 절대 URL 기준)
NEXT_PUBLIC_SITE_URL="https://example.com"

# 백엔드 API URL (next.config.ts의 rewrites 프록시 대상)
# 로컬: http://localhost:3001
# 배포: https://your-api.vercel.app
API_URL="http://localhost:3001"

# 카카오 (공유 + 지도) — https://developers.kakao.com 에서 앱 생성 후 JavaScript 키 입력
# 미설정 시 지도는 SVG 플레이스홀더로 표시되고, 카카오톡 공유는 링크 복사로 폴백
# NEXT_PUBLIC_KAKAO_APP_KEY="발급받은_JavaScript_앱키"

# 검색엔진 인증 (선택)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
# NEXT_PUBLIC_NAVER_SITE_VERIFICATION=""
