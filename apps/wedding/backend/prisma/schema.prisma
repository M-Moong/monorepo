generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Supabase connection pooling (Vercel 서버리스 환경)
  directUrl = env("DIRECT_URL")
}

model GuestEntry {
  id        String   @id @default(cuid())
  name      String
  message   String
  reaction  String   @default("🫶")
  side      String   @default("guest") // "groom" | "bride" | "guest"
  attend    String? // "yes" | "maybe" | "no"
  createdAt DateTime @default(now())
}
