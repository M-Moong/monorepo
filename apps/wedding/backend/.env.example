# ── 로컬 개발 ──────────────────────────────────────────────────────────────────
# 로컬에서 PostgreSQL 사용 시 아래 두 줄 모두 동일하게 입력
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/wedding"
# DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/wedding"

# ── Supabase (Vercel 배포) ──────────────────────────────────────────────────────
# Supabase 대시보드 → Settings → Database → Connection string
#
# Transaction pooler — Vercel 서버리스용 (포트 6543, pgbouncer=true)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# Direct connection — prisma migrate 실행용 (포트 5432)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── CORS ───────────────────────────────────────────────────────────────────────
# 로컬: http://localhost:3000
# 배포: https://your-frontend.vercel.app
WEB_URL="http://localhost:3000"
