# 로컬 개발 (SQLite)
DATABASE_URL="file:./prisma/dev.db"

# 배포 (Supabase PostgreSQL)
# 1. schema.prisma의 provider를 "postgresql"로 변경
# 2. 아래 URL을 Supabase > Settings > Database > Connection string 값으로 교체
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# 카카오 공유 (선택)
# NEXT_PUBLIC_KAKAO_APP_KEY="카카오 개발자 콘솔에서 발급"
