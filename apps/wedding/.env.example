# ─────────────────────────────────────────────────────────────────────────────
# 로컬 개발 DB (SQLite)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"

# 배포 DB (Supabase PostgreSQL)
# 1. prisma/schema.prisma 의 provider 를 "postgresql" 로 변경
# 2. 아래 URL 을 Supabase > Settings > Database > Connection string 값으로 교체
# 3. pnpm prisma db push 실행
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# ─────────────────────────────────────────────────────────────────────────────
# 사이트 도메인 (OG 메타데이터 절대 URL 기준)
# Vercel 배포 후 실제 URL 로 반드시 교체
# ex) https://minjun-seoyeon.vercel.app
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://example.com"

# ─────────────────────────────────────────────────────────────────────────────
# 카카오 공유 (CH09 공유 버튼)
# https://developers.kakao.com → 앱 만들기 → JavaScript 앱 키 복사
# 미설정 시 카카오 공유 대신 링크 복사로 폴백됨
# ─────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_KAKAO_APP_KEY="발급받은_앱키"

# ─────────────────────────────────────────────────────────────────────────────
# 검색엔진 소유권 인증 (선택 — robots: noindex 사용 시 불필요)
# ─────────────────────────────────────────────────────────────────────────────

# 구글 서치콘솔: https://search.google.com/search-console
# → 속성 추가 → HTML 태그 → content="" 안의 값만 복사
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# 네이버 서치어드바이저: https://searchadvisor.naver.com
# → 사이트 등록 → HTML 태그 → content="" 안의 값만 복사
# NEXT_PUBLIC_NAVER_SITE_VERIFICATION=""
